# TalentMind — example environment configuration.
#
# Copy to `.env` and adjust as needed. EVERY value is optional: TalentMind boots
# and runs fully offline with safe defaults and requires NO secrets. Never commit
# a real `.env` (it is gitignored); only this template is tracked.

# --- AI platform -----------------------------------------------------------
# Active provider: local | openai | claude | gemini | ollama  (default: local)
TALENTMIND_AI_PROVIDER=local
# Model id override for the active provider (default: provider-specific).
TALENTMIND_AI_MODEL=
# Generation controls for real providers.
TALENTMIND_AI_TEMPERATURE=0.2
TALENTMIND_AI_MAX_TOKENS=1200
TALENTMIND_AI_TIMEOUT=30
TALENTMIND_AI_MAX_RETRIES=2
# Response cache (1/0). Directory defaults to data/ai_cache.
TALENTMIND_AI_CACHE_ENABLED=1
TALENTMIND_AI_CACHE_DIR=data/ai_cache
# Telemetry log directory (default: logs).
TALENTMIND_AI_TELEMETRY_DIR=logs
# If 1, provider failures raise instead of falling back to the deterministic composer.
TALENTMIND_AI_STRICT=0

# --- Provider credentials (only for non-local providers) -------------------
# Leave blank unless you switch TALENTMIND_AI_PROVIDER to a hosted provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Ollama endpoint (default: http://localhost:11434)
OLLAMA_HOST=

# --- Runtime environment ---------------------------------------------------
# development | testing | staging | production | air_gapped | offline_enterprise | cloud | hybrid
TALENTMIND_ENV=development
